#!/bin/bash
# awake — keeps macOS awake while target processes are actively working
# Bash 3.2 compatible (macOS /bin/bash — no associative arrays, mapfile, coproc)

TARGETS=("claude" "codex" "opencode" "opencode-cli")
PID_FILE="/tmp/awake.pid"

# Parallel indexed arrays aligned with TARGETS (bash 3.2: no associative arrays)
CAFF_PIDS=()
PROC_PIDS=()
LAST_CPU=()    # last observed CPU time string per target
IDLE_COUNT=()  # consecutive idle polls per target (grace window)

# Flag: set to 1 only inside cmd_start so cleanup is a no-op for stop/status invocations
IS_DAEMON=0
CLEANUP_DONE=0

cleanup() {
    [ "$IS_DAEMON" -eq 0 ] && return
    [ "$CLEANUP_DONE" -eq 1 ] && return
    CLEANUP_DONE=1
    echo "[awake] Shutting down..."
    local i cpid
    for i in "${!CAFF_PIDS[@]}"; do
        cpid="${CAFF_PIDS[$i]}"
        if [ -n "$cpid" ] && kill -0 "$cpid" 2>/dev/null; then
            kill "$cpid" 2>/dev/null
        fi
    done
    rm -f "$PID_FILE"
}

# SIGTERM/SIGINT: run cleanup then exit (EXIT trap will call cleanup again but CLEANUP_DONE guards it)
trap 'cleanup; exit 0' SIGTERM SIGINT
trap cleanup EXIT

# --------------------------------------------------------------------------- #
# cmd_start: enter polling loop                                                #
# --------------------------------------------------------------------------- #
cmd_start() {
    # Check for existing live instance
    if [ -f "$PID_FILE" ]; then
        local existing_pid
        existing_pid=$(cat "$PID_FILE")
        if kill -0 "$existing_pid" 2>/dev/null; then
            echo "[awake] Already running (PID $existing_pid)"
            exit 1
        fi
        echo "[awake] Removing stale PID file"
    fi

    echo $$ > "$PID_FILE"
    IS_DAEMON=1
    echo "[awake] Started (PID $$)"

    local i name proc_pid caff_pid old_pid cur_cpu last_cpu idle_count
    while true; do
        for i in "${!TARGETS[@]}"; do
            name="${TARGETS[$i]}"
            proc_pid=$(pgrep -x "$name" | head -1)

            if [ -n "$proc_pid" ]; then
                # Measure CPU time to detect activity
                cur_cpu=$(ps -p "$proc_pid" -o cputime= 2>/dev/null | tr -d ' ')
                last_cpu="${LAST_CPU[$i]:-}"
                idle_count="${IDLE_COUNT[$i]:-0}"

                # New PID or first observation: treat as active
                if [ "${PROC_PIDS[$i]:-}" != "$proc_pid" ]; then
                    PROC_PIDS[$i]=$proc_pid
                    LAST_CPU[$i]="$cur_cpu"
                    IDLE_COUNT[$i]=0
                    idle_count=0
                elif [ -n "$cur_cpu" ] && [ "$cur_cpu" != "$last_cpu" ]; then
                    # CPU time changed — process is working
                    LAST_CPU[$i]="$cur_cpu"
                    IDLE_COUNT[$i]=0
                    idle_count=0
                else
                    # CPU time unchanged — increment idle counter
                    idle_count=$((idle_count + 1))
                    IDLE_COUNT[$i]=$idle_count
                fi

                caff_pid="${CAFF_PIDS[$i]:-}"

                if [ "$idle_count" -lt 3 ]; then
                    # Active (or within grace window) — ensure caffeinate is running
                    if [ -z "$caff_pid" ] || ! kill -0 "$caff_pid" 2>/dev/null; then
                        caffeinate -di &
                        CAFF_PIDS[$i]=$!
                        echo "[awake] $name (PID $proc_pid) is active — caffeinate started"
                    fi
                else
                    # Idle beyond grace window — release caffeinate
                    if [ -n "$caff_pid" ] && kill -0 "$caff_pid" 2>/dev/null; then
                        kill "$caff_pid" 2>/dev/null
                        CAFF_PIDS[$i]=""
                        echo "[awake] $name (PID $proc_pid) idle — caffeinate released"
                    fi
                fi
            else
                # Target is not running — release caffeinate if we had one
                caff_pid="${CAFF_PIDS[$i]:-}"
                if [ -n "${PROC_PIDS[$i]:-}" ]; then
                    old_pid="${PROC_PIDS[$i]}"
                    if [ -n "$caff_pid" ] && kill -0 "$caff_pid" 2>/dev/null; then
                        kill "$caff_pid" 2>/dev/null
                    fi
                    CAFF_PIDS[$i]=""
                    PROC_PIDS[$i]=""
                    LAST_CPU[$i]=""
                    IDLE_COUNT[$i]=0
                    echo "[awake] $name (PID $old_pid) exited — caffeinate released"
                fi
            fi
        done

        # sleep in background + wait so SIGTERM/SIGINT interrupts wait immediately
        sleep 5 &
        wait $!
    done
}

# --------------------------------------------------------------------------- #
# cmd_stop: signal the running awake instance                                  #
# --------------------------------------------------------------------------- #
cmd_stop() {
    if [ ! -f "$PID_FILE" ]; then
        echo "[awake] Not running"
        exit 1
    fi

    local pid
    pid=$(cat "$PID_FILE")
    if kill -0 "$pid" 2>/dev/null; then
        kill "$pid"
        echo "[awake] Stopped (PID $pid)"
    else
        echo "[awake] Not running (stale PID file)"
        rm -f "$PID_FILE"
        exit 1
    fi
}

# --------------------------------------------------------------------------- #
# cmd_status: report current state                                             #
# --------------------------------------------------------------------------- #
cmd_status() {
    if [ ! -f "$PID_FILE" ]; then
        echo "[awake] Status: stopped"
        return
    fi

    local pid
    pid=$(cat "$PID_FILE")
    if ! kill -0 "$pid" 2>/dev/null; then
        echo "[awake] Status: stopped (stale PID file)"
        return
    fi

    echo "[awake] Status: running (PID $pid)"

    # Show which targets are currently detectable
    local name proc_pid
    for name in "${TARGETS[@]}"; do
        proc_pid=$(pgrep -x "$name" | head -1)
        if [ -n "$proc_pid" ]; then
            echo "[awake]   $name: detected (PID $proc_pid) — checking CPU activity"
        else
            echo "[awake]   $name: not detected"
        fi
    done

    # Note: caffeinate active state is tracked only in the daemon process memory
    echo "[awake]   caffeinate: active only when target shows CPU activity (15s grace window)"
}

# --------------------------------------------------------------------------- #
# cmd_install: create LaunchAgent plist and load it                           #
# --------------------------------------------------------------------------- #
cmd_install() {
    local SCRIPT_PATH
    SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
    local PLIST_DIR="$HOME/Library/LaunchAgents"
    local PLIST_FILE="$PLIST_DIR/com.awake.agent.plist"
    local LOG_DIR="$HOME/Library/Logs"

    mkdir -p "$PLIST_DIR"
    mkdir -p "$LOG_DIR"

    cat > "$PLIST_FILE" << EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.awake.agent</string>
    <key>ProgramArguments</key>
    <array>
        <string>$SCRIPT_PATH</string>
        <string>start</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ProcessType</key>
    <string>Background</string>
    <key>StandardOutPath</key>
    <string>$HOME/Library/Logs/awake.log</string>
    <key>StandardErrorPath</key>
    <string>$HOME/Library/Logs/awake.err</string>
    <key>ThrottleInterval</key>
    <integer>10</integer>
</dict>
</plist>
EOF

    echo "[awake] Plist written to $PLIST_FILE"

    if launchctl bootstrap "gui/$(id -u)" "$PLIST_FILE" 2>/dev/null; then
        echo "[awake] LaunchAgent loaded via bootstrap"
    elif launchctl load "$PLIST_FILE" 2>/dev/null; then
        echo "[awake] LaunchAgent loaded via load (fallback)"
    else
        echo "[awake] Warning: failed to load LaunchAgent (plist still installed)"
    fi
}

# --------------------------------------------------------------------------- #
# cmd_uninstall: unload LaunchAgent and remove plist                          #
# --------------------------------------------------------------------------- #
cmd_uninstall() {
    local PLIST_FILE="$HOME/Library/LaunchAgents/com.awake.agent.plist"

    if launchctl bootout "gui/$(id -u)/com.awake.agent" 2>/dev/null; then
        echo "[awake] LaunchAgent unloaded via bootout"
    elif launchctl unload "$PLIST_FILE" 2>/dev/null; then
        echo "[awake] LaunchAgent unloaded via unload (fallback)"
    else
        echo "[awake] Warning: failed to unload LaunchAgent (may not be loaded)"
    fi

    if [ -f "$PLIST_FILE" ]; then
        rm -f "$PLIST_FILE"
        echo "[awake] Plist removed: $PLIST_FILE"
    else
        echo "[awake] Plist not found: $PLIST_FILE"
    fi
}

# --------------------------------------------------------------------------- #
# Dispatch                                                                     #
# --------------------------------------------------------------------------- #
case "${1:-}" in
    start)  cmd_start ;;
    stop)   cmd_stop ;;
    status) cmd_status ;;
    install)   cmd_install ;;
    uninstall) cmd_uninstall ;;
    *)
        echo "Usage: $0 {start|stop|status|install|uninstall}"
        exit 1
        ;;
esac
