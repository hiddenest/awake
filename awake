#!/bin/bash
# awake — keeps macOS awake while target processes are running
# Bash 3.2 compatible (macOS /bin/bash — no associative arrays, mapfile, coproc)

TARGETS=("claude" "codex")
PID_FILE="/tmp/awake.pid"

# Parallel indexed arrays aligned with TARGETS (bash 3.2: no associative arrays)
CAFF_PIDS=()
PROC_PIDS=()

# Flag: set to 1 only inside cmd_start so cleanup is a no-op for stop/status invocations
IS_DAEMON=0
CLEANUP_DONE=0

cleanup() {
    [ "$IS_DAEMON" -eq 0 ] && return
    [ "$CLEANUP_DONE" -eq 1 ] && return
    CLEANUP_DONE=1
    echo "[awake] Shutting down..."
    local i cpid
    for i in "${!CAFF_PIDS[@]}"; do
        cpid="${CAFF_PIDS[$i]}"
        if [ -n "$cpid" ] && kill -0 "$cpid" 2>/dev/null; then
            kill "$cpid" 2>/dev/null
        fi
    done
    rm -f "$PID_FILE"
}

# SIGTERM/SIGINT: run cleanup then exit (EXIT trap will call cleanup again but CLEANUP_DONE guards it)
trap 'cleanup; exit 0' SIGTERM SIGINT
trap cleanup EXIT

# --------------------------------------------------------------------------- #
# cmd_start: enter polling loop                                                #
# --------------------------------------------------------------------------- #
cmd_start() {
    # Check for existing live instance
    if [ -f "$PID_FILE" ]; then
        local existing_pid
        existing_pid=$(cat "$PID_FILE")
        if kill -0 "$existing_pid" 2>/dev/null; then
            echo "[awake] Already running (PID $existing_pid)"
            exit 1
        fi
        echo "[awake] Removing stale PID file"
    fi

    echo $$ > "$PID_FILE"
    IS_DAEMON=1
    echo "[awake] Started (PID $$)"

    local i name proc_pid caff_pid old_pid
    while true; do
        for i in "${!TARGETS[@]}"; do
            name="${TARGETS[$i]}"
            proc_pid=$(pgrep -x "$name" | head -1)
            caff_pid="${CAFF_PIDS[$i]:-}"

            if [ -n "$proc_pid" ]; then
                # Target is running — ensure caffeinate is active
                if [ -z "$caff_pid" ] || ! kill -0 "$caff_pid" 2>/dev/null; then
                    caffeinate -di -w "$proc_pid" &
                    CAFF_PIDS[$i]=$!
                    PROC_PIDS[$i]=$proc_pid
                    echo "[awake] Detected $name (PID $proc_pid) — caffeinate active"
                fi
            else
                # Target is not running — release caffeinate if we had one
                if [ -n "${PROC_PIDS[$i]:-}" ]; then
                    old_pid="${PROC_PIDS[$i]}"
                    if [ -n "$caff_pid" ] && kill -0 "$caff_pid" 2>/dev/null; then
                        kill "$caff_pid" 2>/dev/null
                    fi
                    CAFF_PIDS[$i]=""
                    PROC_PIDS[$i]=""
                    echo "[awake] $name (PID $old_pid) exited — caffeinate released"
                fi
            fi
        done

        # sleep in background + wait so SIGTERM/SIGINT interrupts wait immediately
        sleep 5 &
        wait $!
    done
}

# --------------------------------------------------------------------------- #
# cmd_stop: signal the running awake instance                                  #
# --------------------------------------------------------------------------- #
cmd_stop() {
    if [ ! -f "$PID_FILE" ]; then
        echo "[awake] Not running"
        exit 1
    fi

    local pid
    pid=$(cat "$PID_FILE")
    if kill -0 "$pid" 2>/dev/null; then
        kill "$pid"
        echo "[awake] Stopped (PID $pid)"
    else
        echo "[awake] Not running (stale PID file)"
        rm -f "$PID_FILE"
        exit 1
    fi
}

# --------------------------------------------------------------------------- #
# cmd_status: report current state                                             #
# --------------------------------------------------------------------------- #
cmd_status() {
    if [ ! -f "$PID_FILE" ]; then
        echo "[awake] Status: stopped"
        return
    fi

    local pid
    pid=$(cat "$PID_FILE")
    if ! kill -0 "$pid" 2>/dev/null; then
        echo "[awake] Status: stopped (stale PID file)"
        return
    fi

    echo "[awake] Status: running (PID $pid)"

    # Show which targets are currently detectable
    local name proc_pid
    for name in "${TARGETS[@]}"; do
        proc_pid=$(pgrep -x "$name" | head -1)
        if [ -n "$proc_pid" ]; then
            echo "[awake]   $name: detected (PID $proc_pid)"
        else
            echo "[awake]   $name: not detected"
        fi
    done

    # Note: caffeinate active state is tracked only in the daemon process memory
    echo "[awake]   caffeinate: active if any target is detected"
}

# --------------------------------------------------------------------------- #
# Dispatch                                                                     #
# --------------------------------------------------------------------------- #
case "${1:-}" in
    start)  cmd_start ;;
    stop)   cmd_stop ;;
    status) cmd_status ;;
    *)
        echo "Usage: $0 {start|stop|status}"
        exit 1
        ;;
esac
